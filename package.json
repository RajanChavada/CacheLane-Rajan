{
  "name": "cachelane",
  "version": "1.1.0",
  "description": "Cache-aware prompt orchestration for Claude Code",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "cachelane": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "benchmark:recorded": "tsx scripts/benchmark/run-recorded.ts --provider fake --run-id recorded-local --markdown",
    "benchmark:correctness": "tsx scripts/benchmark/run-correctness.ts",
    "benchmark:latency": "tsx scripts/benchmark/run-latency-ab.ts",
    "doctor:ci": "tsx scripts/doctor-ci.ts",
    "postinstall": "node scripts/postinstall.mjs 2>/dev/null || true"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@aws-sdk/credential-provider-node": "^3.972.55",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "aws4": "^1.13.2",
    "better-sqlite3": "^11.10.0",
    "commander": "^12.0.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/aws4": "^1.11.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "tailwindcss": "^4.3.1",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
